# Environment Variables for Local Development
DATABASE_URL=postgresql://user:password@localhost:5432/suitecraft
STARTUP_CREATE_SCHEMA=false

# Security
SECRET_KEY=your-secret-key-change-in-production
ENCRYPTION_KEY=your-encryption-key-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AI Configuration - Gemini, Groq, or Ollama
USE_GEMINI=false
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-flash-latest

# Groq
USE_GROQ=false
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant

# Ollama (for local development - optional if using Gemini or Groq)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
FRONTEND_URL=http://localhost:5173

# Email (optional, required for real password reset delivery)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# CSV Data 
# JIRA data loaded from: backend/jira_data.csv (554 tickets)
# TestRail data loaded from: backend/testrail_testcases.csv

# Optional: Live Jira API Integration
# JIRA_API_URL=https://your-site.atlassian.net
# JIRA_CLOUD_ID=your-atlassian-cloud-id
# JIRA_API_EMAIL=your.name@company.com
# JIRA_API_TOKEN=your-atlassian-api-token

# Optional: TestRail API Integration 
#TESTRAIL_URL=
#TESTRAIL_API_KEY=
#TESTRAIL_USER=
#TESTRAIL_PROJECT_ID=1
#TESTRAIL_SUITE_ID=292
